{
  "extractor": {
    "bluesky": {
      "cookies": ["zen"],
      "filename": "{createdAt[:19].replace(':', '-')}_{author[handle]}_{post_id}_{num}.{extension}",
      "directory": ["Bluesky", "{author[handle]}"],
      "metadata": ["user", "facets"],
      "include": "likes,media",
      "archive": "~/gallery-dl/archive-bluesky.sqlite3"
    }
  },
  
  "postprocessors": [
    {
      "name": "exec",
      "command": [
        "exiftool", "-overwrite_original",
        "-charset", "utf8",
        "-IPTC:By-line={author[handle]}",
        "-IPTC:Caption-Abstract={description}",
        "-IPTC:Keywords=bluesky,{author[handle]}",
        "-XMP:Creator={author[handle]}",
        "-XMP:Artist={author[displayName]}",
        "-XMP:Description={description}",
        "-XMP:Source=https://bsky.app/profile/{author[handle]}/post/{post_id}",
        "-Comment=Author: {author[handle]} | Source: https://bsky.app/profile/{author[handle]}/post/{post_id}",
        "{_path}"
      ],
      "filter": "extension in ('jpg', 'jpeg', 'png', 'tiff', 'tif')"
    }
  ]
}
